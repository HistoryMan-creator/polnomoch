<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Тренажер: Органы власти РФ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #f8fafc;
            -webkit-tap-highlight-color: transparent;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            overscroll-behavior-y: none;
        }
        
        .app-container {
            max-width: 480px;
            margin: 0 auto;
            background: #f1f5f9;
            min-height: 100vh;
            min-height: -webkit-fill-available;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 40px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }

        /* Мягкие карточки */
        .glass-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 12px 36px rgba(20, 20, 40, 0.04), 0 2px 8px rgba(20, 20, 40, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.9);
        }

        /* Анимации карточек */
        .card-enter {
            animation: slideIn 0.35s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        .card-exit {
            animation: slideOut 0.35s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        @keyframes slideIn {
            from { transform: translateX(100%) scale(0.95); opacity: 0; }
            to { transform: translateX(0) scale(1); opacity: 1; }
        }

        @keyframes slideOut {
            from { transform: translateX(0) scale(1); opacity: 1; }
            to { transform: translateX(-100%) scale(0.95); opacity: 0; }
        }

        .shake {
            animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
        }

        @keyframes shake {
            10%, 90% { transform: translate3d(-2px, 0, 0); }
            20%, 80% { transform: translate3d(4px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-6px, 0, 0); }
            40%, 60% { transform: translate3d(6px, 0, 0); }
        }

        .pop {
            animation: pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.4); }
            100% { transform: scale(1); }
        }

        /* Кнопки */
        .btn-option {
            transition: transform 0.15s ease-out, box-shadow 0.15s ease-out, background-color 0.15s ease;
        }
        
        .btn-option:active {
            transform: scale(0.92);
        }

        .progress-bar-fill {
            transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        .dot {
            transition: background-color 0.2s ease;
        }

        /* Декор на фоне */
        .bg-blob {
            position: absolute;
            filter: blur(60px);
            opacity: 0.6;
            z-index: 0;
            border-radius: 50%;
        }
        
        /* Утилиты для динамического перекрытия стилей */
        .override-success {
            background-color: #22c55e !important;
            color: white !important;
            border-color: #16a34a !important;
        }
        .override-success span { color: white !important; }
        
        .override-error {
            background-color: #ef4444 !important;
            color: white !important;
            border-color: #dc2626 !important;
        }
        .override-error span { color: white !important; }
    </style>
</head>
<body class="text-gray-800 antialiased selection:bg-indigo-100">

    <div class="app-container" id="app">
        <!-- Декоративные пятна на фоне -->
        <div class="bg-blob w-64 h-64 bg-cyan-200 top-[-10%] left-[-20%]"></div>
        <div class="bg-blob w-64 h-64 bg-indigo-200 bottom-[20%] right-[-20%]"></div>
        
        <!-- START SCREEN -->
        <div id="screen-start" class="flex flex-col items-center justify-center h-screen p-6 text-center z-10 relative">
            <div class="w-32 h-32 bg-white rounded-[2rem] shadow-xl flex items-center justify-center mb-8 border border-white relative">
                <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 to-cyan-50 rounded-[2rem] opacity-50"></div>
                <div class="text-indigo-600 relative z-10 text-5xl">
                    🏛️
                </div>
            </div>
            
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2 tracking-tight leading-tight">Органы власти РФ</h1>
            <p class="text-gray-500 mb-10 text-lg font-medium px-4">Президент, СФ, Госдума, Правительство и Суды</p>
            
            <button onclick="startGame()" class="w-full bg-slate-900 text-white font-bold py-4 rounded-2xl shadow-[0_8px_20px_rgba(15,23,42,0.2)] btn-option text-lg relative overflow-hidden">
                <span class="relative z-10">Начать тренировку</span>
            </button>
            <p class="text-xs text-gray-400 mt-6 uppercase tracking-widest font-semibold" id="start-total">Загрузка...</p>
        </div>

        <!-- QUIZ SCREEN -->
        <div id="screen-quiz" class="hidden flex-col h-screen relative z-10">
            <!-- Top bar -->
            <div class="px-5 pt-8 pb-4">
                <div class="flex justify-between items-end mb-3">
                    <span class="text-xs font-bold text-gray-400 uppercase tracking-wider" id="mastered-counter">Выучено: 0/0</span>
                    <span class="text-xs font-bold text-indigo-600 bg-indigo-100 px-3 py-1 rounded-full border border-indigo-200" id="pool-counter">Осталось: 0</span>
                </div>
                <div class="w-full bg-slate-200/60 rounded-full h-1.5 overflow-hidden">
                    <div id="progress-bar" class="progress-bar-fill bg-indigo-500 h-1.5 rounded-full" style="width: 0%"></div>
                </div>
            </div>

            <!-- Card Area -->
            <div class="flex-1 flex flex-col justify-center px-4 pb-2 relative" id="card-container">
                <div id="question-card" class="w-full glass-card p-6 md:p-8 flex flex-col items-center text-center relative overflow-hidden min-h-[220px] justify-center">
                    
                    <!-- Индикаторы прогресса ответа (точки) -->
                    <div class="flex space-x-2.5 mb-4 absolute top-5" id="streak-dots">
                        <!-- Точки генерируются через JS -->
                    </div>

                    <h2 id="question-text" class="text-[18px] md:text-[20px] font-medium text-gray-800 leading-snug tracking-tight mt-6">Загрузка...</h2>
                </div>
            </div>

            <!-- Action Area (6 buttons grid) -->
            <div class="px-4 pb-6 pt-2">
                <div class="grid grid-cols-2 gap-2.5">
                    <!-- Президент -->
                    <button onclick="checkAnswer('p', this)" class="btn-option bg-white border-2 border-blue-50/50 rounded-2xl p-3 flex flex-col items-center justify-center text-center shadow-sm relative overflow-hidden">
                        <div class="absolute inset-0 bg-blue-50/30"></div>
                        <span class="text-2xl mb-1 relative z-10">🦅</span>
                        <span class="text-[13px] font-bold text-blue-800 relative z-10">Президент</span>
                    </button>
                    <!-- Правительство -->
                    <button onclick="checkAnswer('pr', this)" class="btn-option bg-white border-2 border-emerald-50/50 rounded-2xl p-3 flex flex-col items-center justify-center text-center shadow-sm relative overflow-hidden">
                        <div class="absolute inset-0 bg-emerald-50/30"></div>
                        <span class="text-2xl mb-1 relative z-10">💼</span>
                        <span class="text-[13px] font-bold text-emerald-800 relative z-10">Правительство</span>
                    </button>
                    <!-- Совет Федерации -->
                    <button onclick="checkAnswer('sf', this)" class="btn-option bg-white border-2 border-indigo-50/50 rounded-2xl p-3 flex flex-col items-center justify-center text-center shadow-sm relative overflow-hidden">
                        <div class="absolute inset-0 bg-indigo-50/30"></div>
                        <span class="text-2xl mb-1 relative z-10">🇷🇺</span>
                        <span class="text-[13px] font-bold text-indigo-800 relative z-10">Совет Федерации</span>
                    </button>
                    <!-- Госдума -->
                    <button onclick="checkAnswer('gd', this)" class="btn-option bg-white border-2 border-purple-50/50 rounded-2xl p-3 flex flex-col items-center justify-center text-center shadow-sm relative overflow-hidden">
                        <div class="absolute inset-0 bg-purple-50/30"></div>
                        <span class="text-2xl mb-1 relative z-10">🗳️</span>
                        <span class="text-[13px] font-bold text-purple-800 relative z-10">Госдума</span>
                    </button>
                    <!-- Конст. Суд -->
                    <button onclick="checkAnswer('ks', this)" class="btn-option bg-white border-2 border-orange-50/50 rounded-2xl p-3 flex flex-col items-center justify-center text-center shadow-sm relative overflow-hidden">
                        <div class="absolute inset-0 bg-orange-50/30"></div>
                        <span class="text-2xl mb-1 relative z-10">⚖️</span>
                        <span class="text-[13px] font-bold text-orange-800 relative z-10">Конст. Суд</span>
                    </button>
                    <!-- Верховный Суд -->
                    <button onclick="checkAnswer('vs', this)" class="btn-option bg-white border-2 border-rose-50/50 rounded-2xl p-3 flex flex-col items-center justify-center text-center shadow-sm relative overflow-hidden">
                        <div class="absolute inset-0 bg-rose-50/30"></div>
                        <span class="text-2xl mb-1 relative z-10">🔨</span>
                        <span class="text-[13px] font-bold text-rose-800 relative z-10">Верховный Суд</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- RESULT SCREEN (CERTIFICATE) -->
        <div id="screen-result" class="hidden flex-col items-center justify-center h-screen p-5 z-10 relative">
            
            <!-- Сертификат для скриншота -->
            <div class="w-full bg-white rounded-[32px] p-8 shadow-2xl relative overflow-hidden mb-8 border border-slate-100 flex flex-col items-center text-center">
                
                <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-cyan-400 via-blue-500 to-indigo-600"></div>
                
                <p class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase mb-6 mt-2">Сертификат результата</p>
                
                <div class="text-[70px] leading-none mb-3 drop-shadow-md">🎓</div>
                
                <h3 class="text-2xl font-black text-slate-900 mb-1">Экзамен сдан!</h3>
                <p class="text-sm text-slate-500 mb-6">Органы власти РФ (Главы 4-7)</p>
                
                <div class="bg-gradient-to-br from-indigo-50 to-cyan-50 rounded-2xl w-full py-5 mb-8 border border-indigo-100/50 shadow-inner">
                    <p class="text-5xl font-black text-indigo-600 tracking-tight" id="cert-score">0 / 0</p>
                    <p class="text-[11px] text-indigo-400 font-bold mt-1 uppercase tracking-widest">верных ответов</p>
                </div>
                
                <div class="w-full border-t border-dashed border-slate-200 pt-5 flex justify-between items-center px-1">
                    <div class="text-left">
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1">Дата</p>
                        <p class="text-xs text-slate-700 font-medium" id="cert-date">--.--.----</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1">Статус</p>
                        <p class="text-xs text-emerald-600 font-bold bg-emerald-50 px-2 py-0.5 rounded uppercase tracking-wider border border-emerald-100">Эксперт</p>
                    </div>
                </div>
            </div>
            
            <button onclick="startGame()" class="w-full bg-slate-900 text-white font-bold py-4 rounded-2xl shadow-lg btn-option text-lg">
                Повторить тренировку
            </button>
        </div>

    </div>

    <script>
        // Полная база данных на основе предоставленного PDF-документа (Все 78 пунктов)
        // Типы: p (Президент), sf (Совет Федерации), gd (Госдума), pr (Правительство), ks (Конституционный Суд), vs (Верховный Суд)
        const dbQuestions = [
            { id: 1, text: "Является главой государства", type: "p" },
            { id: 2, text: "Является гарантом Конституции", type: "p" },
            { id: 3, text: "Является гарантом прав и свобод человека и гражданина", type: "p" },
            { id: 4, text: "Принимает меры по охране суверенитета Российской Федерации, ее независимости и государственной целостности", type: "p" },
            { id: 5, text: "Обеспечивает согласованное функционирование и взаимодействие органов, входящих в единую систему публичной власти", type: "p" },
            { id: 6, text: "Определяет основные направления внутренней и внешней политики государства", type: "p" },
            { id: 7, text: "Представляет Российскую Федерацию внутри страны и в международных отношениях", type: "p" },
            { id: 8, text: "Назначает с согласия Государственной Думы Председателя Правительства", type: "p" },
            { id: 9, text: "Имеет право председательствовать на заседаниях Правительства", type: "p" },
            { id: 10, text: "Принимает решение об отставке Правительства", type: "p" },
            { id: 11, text: "Формирует и возглавляет Совет Безопасности", type: "p" },
            { id: 12, text: "Утверждает военную доктрину", type: "p" },
            { id: 13, text: "Назначает и освобождает высшее командование Вооруженных Сил", type: "p" },
            { id: 14, text: "Назначает и отзывает послов", type: "p" },
            { id: 15, text: "Назначает выборы Государственной Думы", type: "p" },
            { id: 16, text: "Распускает Государственную Думу в случаях и порядке, предусмотренных Конституцией", type: "p" },
            { id: 17, text: "Назначает референдум", type: "p" },
            { id: 18, text: "Подписывает и обнародует федеральные законы", type: "p" },
            { id: 19, text: "Осуществляет руководство внешней политикой", type: "p" },
            { id: 20, text: "Ведет переговоры и подписывает международные договоры", type: "p" },
            { id: 21, text: "Является Верховным Главнокомандующим Вооруженными Силами Российской Федерации", type: "p" },
            { id: 22, text: "Вводит на территории Российской Федерации или в отдельных ее местностях военное и чрезвычайное положение с незамедлительным сообщением об этом Совету Федерации и Государственной Думе", type: "p" },
            { id: 23, text: "Решает вопрос гражданства и предоставления политического убежища", type: "p" },
            { id: 24, text: "Награждает государственными наградами, присваивает почетные звания, высшие воинские и высшие специальные звания", type: "p" },
            { id: 25, text: "Осуществляет помилование", type: "p" },
            { id: 26, text: "Издает указы и распоряжения", type: "p" },
            { id: 27, text: "Утверждает изменения границ между субъектами РФ", type: "sf" },
            { id: 28, text: "Утверждает указ Президента РФ о введении военного или чрезвычайного положения", type: "sf" },
            { id: 29, text: "Решает вопрос о возможности использования Вооруженных Сил РФ за пределами территории РФ", type: "sf" },
            { id: 30, text: "Назначает выборы Президента", type: "sf" },
            { id: 31, text: "По представлению Президента назначает на должность судей Конституционного Суда, Верховного Суда", type: "sf" },
            { id: 32, text: "Назначает на должность и освобождает от должности Генерального прокурора", type: "p" },
            { id: 33, text: "Даёт согласие Президенту на назначение Председателя Правительства", type: "gd" },
            { id: 34, text: "Решает вопрос о доверии Правительству", type: "gd" },
            { id: 35, text: "Назначает на должность и освобождает от должности Председателя Центрального банка", type: "gd" },
            { id: 36, text: "Назначение на должность и освобождение от должности заместителя Председателя Счетной палаты и половины от общего числа аудиторов Счетной палаты по представлению Президента РФ", type: "gd" },
            { id: 37, text: "Назначает на должность и освобождает от должности Уполномоченного по правам человека", type: "gd" },
            { id: 38, text: "Объявляет амнистию", type: "gd" },
            { id: 39, text: "Выдвигает обвинения против Президента для отрешения его от должности", type: "gd" },
            { id: 40, text: "Принимает федеральные законы", type: "gd" },
            { id: 41, text: "Разрабатывает и представляет Государственной Думе федеральный бюджет", type: "pr" },
            { id: 42, text: "Обеспечивает исполнение федерального бюджета", type: "pr" },
            { id: 43, text: "Обеспечивает проведение единой финансовой, кредитной и денежной политики", type: "pr" },
            { id: 44, text: "Обеспечивает проведение единой социально ориентированной государственной политики в области культуры, науки, образования, здравоохранения, социального обеспечения, поддержки, укрепления и защиты семьи, сохранения традиционных семейных ценностей, а также в области охраны окружающей среды", type: "pr" },
            { id: 45, text: "Осуществляет управление федеральной собственностью", type: "pr" },
            { id: 46, text: "Осуществляет меры по обеспечению обороны страны, государственной безопасности, реализации внешней политики Российской Федерации", type: "pr" },
            { id: 47, text: "Осуществляет меры по обеспечению законности, прав и свобод граждан, охране собственности и общественного порядка, борьбе с преступностью", type: "pr" },
            { id: 48, text: "Разрешает дела о соответствии нормативных актов и договоров Конституции РФ", type: "ks" },
            { id: 49, text: "Дает толкование Конституции РФ", type: "ks" },
            { id: 50, text: "Даёт заключение о соблюдении установленного порядка выдвижения обвинения Президента в государственной измене или совершении иного тяжкого преступления", type: "ks" },
            { id: 51, text: "Является высшим судебным органом по гражданским, уголовным, административным и иным делам", type: "vs" },
            { id: 52, text: "Одобряет или отклоняет законы, принятые Государственной Думой", type: "sf" },
            { id: 53, text: "Нижняя палата Федерального Собрания", type: "gd" },
            { id: 54, text: "Верхняя палата Федерального Собрания", type: "sf" },
            { id: 55, text: "Избирается на 6 лет", type: "p" },
            { id: 56, text: "Избирается на 5 лет", type: "gd" },
            { id: 57, text: "Избирается по смешанной (мажоритарно-пропорциональной) системе", type: "gd" },
            { id: 58, text: "Каждый субъект РФ назначает в него по 2 сенатора", type: "sf" },
            { id: 59, text: "Разрешает споры о компетенции между органами государственной власти различных уровней", type: "ks" },
            { id: 60, text: "Осуществляет надзор за деятельностью судов общей юрисдикции и арбитражных судов", type: "vs" },
            { id: 61, text: "Обеспечивает государственную поддержку научно-технологического развития Российской Федерации, сохранение и развитие ее научного потенциала", type: "pr" },
            { id: 62, text: "Обеспечивает функционирование системы социальной защиты инвалидов, основанной на полном и равном осуществлении ими прав и свобод человека и гражданина, их социальную интеграцию без какой-либо дискриминации, создание доступной среды для инвалидов и улучшение качества их жизни", type: "pr" },
            { id: 63, text: "Осуществляет меры по поддержке институтов гражданского общества, в том числе некоммерческих организаций, обеспечивает их участие в выработке и проведении государственной политики", type: "pr" },
            { id: 64, text: "Осуществляет меры по поддержке добровольческой (волонтерской) деятельности", type: "pr" },
            { id: 65, text: "Содействует развитию предпринимательства и частной инициативы", type: "pr" },
            { id: 66, text: "Обеспечивает реализацию принципов социального партнерства в сфере регулирования трудовых и иных непосредственно связанных с ними отношений", type: "pr" },
            { id: 67, text: "Осуществляет меры, направленные на создание благоприятных условий жизнедеятельности населения, снижение негативного воздействия хозяйственной и иной деятельности на окружающую среду, сохранение уникального природного и биологического многообразия страны, формирование в обществе ответственного отношения к животным", type: "pr" },
            { id: 68, text: "Создает условия для развития системы экологического образования граждан, воспитания экологической культуры", type: "pr" },
            { id: 69, text: "Представляет Государственной Думе отчет об исполнении федерального бюджета", type: "pr" },
            { id: 70, text: "Заслушивание ежегодных отчетов Центрального банка Российской Федерации", type: "gd" },
            { id: 71, text: "Утверждение по представлению Председателя Правительства РФ кандидатур заместителей Председателя Правительства РФ и некоторых федеральных министров", type: "gd" },
            { id: 72, text: "Назначение на должность и освобождение от должности Председателя Счетной палаты и половины от общего числа аудиторов Счетной палаты по представлению Президента РФ", type: "sf" },
            { id: 73, text: "Заслушивание ежегодных докладов Генерального прокурора РФ о состоянии законности и правопорядка в РФ", type: "sf" },
            { id: 74, text: "Поддерживает гражданский мир и согласие в стране", type: "p" },
            { id: 75, text: "Формирует Государственный Совет", type: "p" },
            { id: 76, text: "Представляет Совету Федерации кандидатуры для назначения на должность Председателя Счетной палаты и половины от общего числа аудиторов Счетной палаты", type: "p" },
            { id: 77, text: "Представляет Государственной Думе кандидатуры для назначения на должность заместителя Председателя Счетной палаты и половины от общего числа аудиторов Счетной палаты", type: "p" },
            { id: 78, text: "Назначает на должность после консультаций с Советом Федерации и освобождает от должности руководителей федеральных органов исполнительной власти (включая федеральных министров), ведающих вопросами обороны, безопасности государства, внутренних дел, юстиции, иностранных дел, предотвращения чрезвычайных ситуаций и ликвидации последствий стихийных бедствий, общественной безопасности", type: "p" }
        ];

        let activePool = [];
        let currentQuestion = null;
        let totalQuestionsCount = 0;
        let masteredQuestionsCount = 0;
        let isAnswering = false; 

        const screenStart = document.getElementById('screen-start');
        const screenQuiz = document.getElementById('screen-quiz');
        const screenResult = document.getElementById('screen-result');
        const questionText = document.getElementById('question-text');
        const questionCard = document.getElementById('question-card');
        const masteredCounter = document.getElementById('mastered-counter');
        const poolCounter = document.getElementById('pool-counter');
        const progressBar = document.getElementById('progress-bar');
        const dotsContainer = document.getElementById('streak-dots');

        // Инициализация при загрузке страницы
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('start-total').textContent = `${dbQuestions.length} карточек`;
        });

        function shuffle(array) {
            let currentIndex = array.length, randomIndex;
            while (currentIndex != 0) {
                randomIndex = Math.floor(Math.random() * currentIndex);
                currentIndex--;
                [array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];
            }
            return array;
        }

        function startGame() {
            // targetStreak - сколько нужно верных ответов подряд. 
            // errorStreak - счетчик ошибок подряд. Если >= 2, увеличиваем targetStreak.
            activePool = dbQuestions.map(q => ({ 
                ...q, 
                streak: 0,
                errorStreak: 0,
                targetStreak: 2 
            }));
            shuffle(activePool);
            
            totalQuestionsCount = activePool.length;
            masteredQuestionsCount = 0;
            
            screenStart.classList.add('hidden');
            screenResult.classList.add('hidden');
            screenQuiz.classList.remove('hidden');
            screenQuiz.classList.add('flex');
            
            showNextQuestion();
        }

        function renderDots(streak, targetStreak, isError = false) {
            dotsContainer.innerHTML = '';
            for (let i = 0; i < targetStreak; i++) {
                const dot = document.createElement('div');
                let bgClass = 'bg-slate-200';
                let extraClass = '';
                
                if (isError) {
                    if (i === 0) bgClass = 'bg-rose-400 pop';
                } else if (i < streak) {
                    bgClass = 'bg-emerald-500';
                    // Анимируем только последнюю заработанную точку
                    if (i === streak - 1 && streak > 0) {
                        extraClass = 'pop';
                    }
                }
                
                dot.className = `dot w-3 h-3 rounded-full ${bgClass} ${extraClass}`;
                dotsContainer.appendChild(dot);
            }
        }

        function flashErrorAndResetDots() {
            renderDots(0, currentQuestion.targetStreak, true);
            setTimeout(() => {
                if (currentQuestion) {
                    renderDots(0, currentQuestion.targetStreak, false);
                }
            }, 400);
        }

        function showNextQuestion() {
            if (activePool.length === 0) {
                endGame();
                return;
            }

            currentQuestion = activePool.shift();
            questionText.textContent = currentQuestion.text;
            
            // Динамический размер текста: сбрасываем старые классы размера
            questionText.className = "font-medium text-gray-800 leading-snug tracking-tight mt-6";
            
            if (currentQuestion.text.length > 200) {
                questionText.classList.add('text-[13px]', 'md:text-[14px]');
            } else if (currentQuestion.text.length > 100) {
                questionText.classList.add('text-[15px]', 'md:text-[17px]');
            } else {
                questionText.classList.add('text-[18px]', 'md:text-[20px]');
            }
            
            // Отрисовываем нужное количество точек
            renderDots(currentQuestion.streak, currentQuestion.targetStreak);
            
            masteredCounter.textContent = `Выучено: ${masteredQuestionsCount}/${totalQuestionsCount}`;
            poolCounter.textContent = `В колоде: ${activePool.length + 1}`;
            
            const progress = (masteredQuestionsCount / totalQuestionsCount) * 100;
            progressBar.style.width = `${progress}%`;

            questionCard.classList.remove('card-exit');
            questionCard.classList.add('card-enter');
            
            isAnswering = false;
        }

        function reinsertIntoPool(question) {
            if (activePool.length === 0) {
                activePool.push(question);
            } else {
                // Если в пуле еще много вопросов, прячем подальше (но не в самый конец, чтобы не было предсказуемо)
                const minIdx = Math.min(3, activePool.length);
                const insertIdx = Math.floor(Math.random() * (activePool.length - minIdx + 1)) + minIdx;
                activePool.splice(insertIdx, 0, question);
            }
        }

        function checkAnswer(selectedType, btnElement) {
            if (isAnswering) return;
            isAnswering = true;

            const isCorrect = selectedType === currentQuestion.type;

            if (isCorrect) {
                // ПРАВИЛЬНЫЙ ОТВЕТ
                currentQuestion.streak++;
                currentQuestion.errorStreak = 0; // Сбрасываем счетчик ошибок
                
                // Визуальный фидбек на кнопке
                btnElement.classList.add('override-success');
                
                renderDots(currentQuestion.streak, currentQuestion.targetStreak);

                if (currentQuestion.streak >= currentQuestion.targetStreak) {
                    masteredQuestionsCount++;
                    // Вопрос выучен, в пул не возвращаем
                } else {
                    reinsertIntoPool(currentQuestion);
                }
            } else {
                // НЕВЕРНЫЙ ОТВЕТ
                currentQuestion.streak = 0;
                currentQuestion.errorStreak++;
                
                // ШТРАФ: если 2 ошибки подряд, увеличиваем сложность (минимум 3 правильных)
                if (currentQuestion.errorStreak >= 2) {
                    currentQuestion.targetStreak = 3;
                }
                
                // Визуальный фидбек
                btnElement.classList.add('override-error');
                questionCard.classList.add('shake');
                
                flashErrorAndResetDots();
                reinsertIntoPool(currentQuestion);
            }

            // Анимация ухода карточки и сброс классов кнопки
            setTimeout(() => {
                btnElement.classList.remove('override-success', 'override-error');
                
                questionCard.classList.remove('shake');
                questionCard.classList.remove('card-enter');
                questionCard.classList.add('card-exit');

                setTimeout(() => {
                    showNextQuestion();
                }, 300);
                
            }, isCorrect ? 500 : 900); // При ошибке даем чуть больше времени посмотреть на правильный/неправильный ответ
        }

        function endGame() {
            screenQuiz.classList.add('hidden');
            screenQuiz.classList.remove('flex');
            screenResult.classList.remove('hidden');
            screenResult.classList.add('flex');
            
            // Обновляем динамические данные для сертификата
            document.getElementById('cert-score').textContent = `${totalQuestionsCount} / ${totalQuestionsCount}`;
            const dateStr = new Date().toLocaleDateString('ru-RU', { 
                day: '2-digit', month: 'long', year: 'numeric' 
            });
            document.getElementById('cert-date').textContent = dateStr;
        }
    </script>
</body>
</html>
